# Email delivery (pick one)
EMAIL_METHOD=gmail              # or "resend"

# Gmail SMTP
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
DIGEST_RECIPIENT=your-email@gmail.com

# Resend (alternative)
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_FROM=jobs@yourdomain.com

# Proxy (optional, for LinkedIn rate limiting)
PROXY_LIST=                     # comma-separated: user:pass@host:port

# LLM scoring - Phase 2 (optional)
ANTHROPIC_API_KEY=              # for Claude-based description analysis

# Schedule
DAILY_RUN_HOUR=7                # 7 AM local time
TIMEZONE=America/Los_Angeles
